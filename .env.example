# ============================================================================
# Пример конфигурации grid-бота. Скопируйте в .env и отредактируйте:
#     cp .env.example .env
# НИКОГДА не коммитьте .env с реальными ключами в git!
# ============================================================================

# --- Биржа ------------------------------------------------------------------
# Какая биржа: binance или bybit. Переключение биржи — только этой строкой.
EXCHANGE_ID=binance

# API-ключ и секрет. Создавайте ключ ТОЛЬКО с правом на торговлю,
# БЕЗ права на вывод средств. Эти значения читаются из окружения и
# не должны нигде хардкодиться. В логи открытым текстом не пишутся.
API_KEY=
API_SECRET=

# --- Безопасность (самые важные переменные) ---------------------------------
# DRY_RUN=true — НИКАКИХ реальных ордеров, заполнения симулируются по реальной
# текущей цене с биржи. Это безопасный режим по умолчанию. Снимайте только
# когда полностью понимаете поведение бота.
DRY_RUN=true

# USE_TESTNET=true — использовать testnet/sandbox биржи (фейковые деньги,
# реальная механика ордеров). Рекомендуемый второй шаг после DRY_RUN.
USE_TESTNET=true

# Kill switch: если equity упадёт на этот % от стартового — бот отменяет все
# ордера и останавливается. Например 20 = остановка при просадке 20%.
MAX_DRAWDOWN_PCT=20

# Жёсткий лимит капитала в котируемой валюте (например, USDT). Бот НИКОГДА
# не использует больше этой суммы, даже если на балансе биржи больше.
TOTAL_CAPITAL=100

# --- Торговая пара и сетка ---------------------------------------------------
# Символ. Для spot: BTC/USDT. Для futures бот сам добавит суффикс (BTC/USDT:USDT).
SYMBOL=BTC/USDT

# Нижняя и верхняя границы ценового диапазона сетки (в котируемой валюте).
# Бот зарабатывает на колебаниях ВНУТРИ диапазона и теряет, если цена
# устойчиво уходит за его пределы без ручной корректировки.
LOWER_PRICE=50000
UPPER_PRICE=70000

# Количество уровней сетки (>= 2). Чем больше уровней — тем чаще мелкие сделки.
NUM_GRIDS=10

# Период опроса цены в секундах.
POLL_SECONDS=10

# --- Тип рынка и плечо -------------------------------------------------------
# spot — без плеча, только то, что есть на балансе (только лонг).
# futures — доступны плечо, режим маржи и шорт. ВНИМАТЕЛЬНО читайте раздел
# про риски в README перед использованием futures.
MARKET_TYPE=spot

# Плечо (целое число >= 1). ВАЖНО: при MARKET_TYPE=spot значение ОБЯЗАНО быть 1,
# иначе бот не запустится (это защита от случайного плеча на споте).
# При futures плечо кратно увеличивает и прибыль, и убытки, и риск ликвидации.
LEVERAGE=1

# Режим маржи для futures: isolated (изолированная — безопаснее, риск ограничен
# маржой позиции) или cross (кросс — рискует всем балансом). Для spot игнорируется.
MARGIN_MODE=isolated

# ============================================================================
# МУЛЬТИТИКЕРНЫЙ РЕЖИМ (авто-выбор портфеля по объёму/росту/волатильности)
# ============================================================================
# MULTI_SYMBOL_MODE=false — классический режим одного тикера (SYMBOL + ручной
# LOWER_PRICE/UPPER_PRICE выше). MULTI_SYMBOL_MODE=true — бот сам отбирает
# портфель тикеров с биржи по трём категориям и торгует их одновременно;
# SYMBOL/LOWER_PRICE/UPPER_PRICE при этом не используются (диапазон считается
# автоматически от текущей цены через GRID_RANGE_PCT).
MULTI_SYMBOL_MODE=false

# Котируемая валюта для отбора: торгуем только пары */QUOTE_CURRENCY
# (не смешиваем котировки в одной выборке).
QUOTE_CURRENCY=USDT

# Сколько тикеров брать из каждой категории:
#  - NUM_TOP_VOLUME   — топ по объёму торгов за 24ч (обычно ликвиднее/спокойнее);
#  - NUM_TOP_GAINERS  — топ по % роста за 24ч (ВНИМАНИЕ: это тренд — плохо для grid);
#  - NUM_TOP_VOLATILE — топ по амплитуде (high-low)/last за 24ч (тоже рискованно).
NUM_TOP_VOLUME=3
NUM_TOP_GAINERS=3
NUM_TOP_VOLATILE=3

# Жёсткий потолок на общее число одновременно торгуемых символов.
MAX_CONCURRENT_SYMBOLS=8

# Минимальный 24ч-объём (в QUOTE_CURRENCY) — отсекает неликвид, из которого
# тяжело выйти. Тикеры с объёмом ниже порога в выборку не попадают.
MIN_24H_VOLUME_USDT=5000000

# Как часто пересобирать портфель (в часах). Слишком частая ребалансировка
# с реальными открытыми позициями создаёт лишний риск и комиссии.
RESCAN_INTERVAL_HOURS=12

# Явный чёрный список (через запятую), напр.: EXCLUDE_SYMBOLS=DOGE,SHIB
EXCLUDE_SYMBOLS=

# Стейблкоины — пары стейбл-к-стейблу (USDC/USDT и т.п.) исключаются:
# для grid там нет волатильности.
STABLECOINS=USDT,USDC,BUSD,DAI,TUSD,FDUSD

# Паттерны плечевых токенов (синтетика) — исключаются как крайне рискованные:
# по умолчанию символы, ОКАНЧИВАЮЩИЕСЯ на эти суффиксы (BTCUP, ETHDOWN, BTC3L...).
LEVERAGED_TOKEN_PATTERNS=UP,DOWN,BULL,BEAR,3L,3S

# --- Вес капитала по категориям (доли; нормализуются автоматически) ---------
# ПОЧЕМУ НЕРАВНОМЕРНО: grid зарабатывает на колебаниях ВНУТРИ диапазона и
# теряет на устойчивом тренде. "Рост"/"волатильность" — это почти по
# определению тренд/резкие движения, т.е. наихудшие условия для grid. Поэтому
# им даётся МЕНЬШИЙ вес капитала (и более жёсткий kill switch внутри бота).
CAPITAL_WEIGHT_VOLUME=1.0
CAPITAL_WEIGHT_GAINER=0.5
CAPITAL_WEIGHT_VOLATILE=0.4

# Ширина авто-диапазона сетки в % от текущей цены (в обе стороны). Например 12
# -> диапазон [price*0.88 .. price*1.12]. Должно быть в (0, 100).
GRID_RANGE_PCT=12

# Портфельный kill switch: если просадка по СУММЕ equity всех символов
# достигает этого %, останавливаются ВСЕ символы и отменяются все ордера.
# Действует поверх per-symbol MAX_DRAWDOWN_PCT.
MAX_PORTFOLIO_DRAWDOWN_PCT=25

# Что делать с символом, выпавшим из выборки при ресканировании:
#  - hold   — не открывать новые уровни, дать текущим ордерам доиграть;
#  - cancel — сразу отменить все ордера символа и остановить его.
WIND_DOWN_POLICY=hold
